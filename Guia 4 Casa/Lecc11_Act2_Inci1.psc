Algoritmo Lecc11_Act2_Inci1
	
    Definir num, i, factorial Como Entero
	
    Escribir "Ingrese un numero entero: "
    Leer num
	
    factorial <- 1
	
    Para i <- 1 Hasta num Hacer
        
        factorial <- factorial * i
		
    FinPara
	
    Escribir "El factorial es: ", factorial
	
FinAlgoritmo