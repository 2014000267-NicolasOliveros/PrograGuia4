Algoritmo Lecc9_Act4_Inci1
	
    Definir num, i, resultado Como Entero
	
    Escribir "Ingrese un numero: "
    Leer num
	
    i <- 1
	
    Repetir
        
        resultado <- num * i
        
        Escribir num, " x ", i, " = ", resultado
        
        i <- i + 1
		
    Hasta Que i > 10
	
FinAlgoritmo